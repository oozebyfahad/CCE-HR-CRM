 rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin()    { return isAuth() && role() == 'admin'; }
    function isHR()       { return isAuth() && (role() == 'admin' || role() == 'hr'); }
    function isTeamLead() { return isAuth() && (role() == 'admin' || role() == 'hr' || role() == 'team_lead'); }

    match /employees/{id} {
      allow read:   if isTeamLead()
                    || (isAuth() && request.auth.token.email == resource.data.email);
      allow create: if isHR();
      allow update: if isHR()
                    || (isAuth()
                        && request.auth.token.email == resource.data.email
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rotacloudId']));
      allow delete: if isAdmin();
    }

    match /users/{id} {
      allow read:   if isAuth() && (request.auth.uid == id || isHR());
      allow create: if isAdmin();
      allow update: if isAdmin() || request.auth.uid == id;
      allow delete: if isAdmin();
    }

    match /attendance/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }

    match /leave_requests/{id} {
      allow read:   if isTeamLead();
      allow create: if isHR();
      allow update: if isHR();
      allow delete: if isHR();
    }

    match /payroll_runs/{runId} {
      allow read:   if isAdmin();
      allow write:  if isAdmin();
      match /entries/{entryId} {
        allow read:   if isAdmin();
        allow write:  if isAdmin();
      }
    }

    match /advances/{id} {
      allow read:   if isHR();
      allow write:  if isHR();
    }

    match /loans/{id} {
      allow read:   if isHR();
      allow write:  if isHR();
    }

    match /applicants/{id} {
      allow create: if true;
      allow read:   if isHR();
      allow update: if isHR();
      allow delete: if isHR();
    }

    match /rejected/{id} {
      allow read:  if true;
      allow write: if isHR();
    }

    match /timesheets/{id} {
      allow read:   if isTeamLead();
      allow write:  if isAuth();
    }

    match /performance/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }

    match /training/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }

    match /disciplinary/{id} {
      allow read:  if isTeamLead()
                   || (isAuth() && request.auth.token.email == resource.data.employeeEmail);
      allow write: if isHR();
    }

    match /staff/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }

    match /shift_notes/{id} {
      allow read:   if isTeamLead();
      allow write:  if isTeamLead();
    }

    match /shift_approvals/{id} {
      allow read:   if isHR();
      allow write:  if isTeamLead();
    }

    match /call_recordings/{id} {
      allow read:  if isHR();
      allow write: if false;
    }

    match /organizations/{id} {
      allow read:   if isAdmin();
      allow write:  if isAdmin();
    }

    match /notifications/{id} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.token.email || isHR());
      allow create: if isHR();
      allow update: if isAuth() && resource.data.userId == request.auth.token.email;
      allow delete: if isAdmin();
    }
  }
}