rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin()    { return isAuth() && role() == 'admin'; }
    function isHR()       { return isAuth() && (role() == 'admin' || role() == 'hr'); }
    function isTeamLead() { return isAuth() && (role() == 'admin' || role() == 'hr' || role() == 'team_lead'); }

    // ── Employees ────────────────────────────────────────────────────
    match /employees/{id} {
      allow read:   if isTeamLead() || (isAuth() && resource.data.email == request.auth.token.email);
      allow create: if isHR();
      allow update: if isHR() || (isAuth() && resource.data.email == request.auth.token.email);
      allow delete: if isAdmin();
    }

    // ── Users (portal accounts) ──────────────────────────────────────
    match /users/{id} {
      allow read:   if isAuth() && (request.auth.uid == id || isHR());
      allow create: if isAdmin();
      allow update: if isAdmin() || request.auth.uid == id;
      allow delete: if isAdmin();
    }

    // ── Shift assignments (employee portal – My Shifts) ───────────────
    match /shift_assignments/{id} {
      allow read:   if isAuth();
      allow write:  if isHR();
    }

    // ── Notices / Noticeboard ─────────────────────────────────────────
    match /notices/{id} {
      allow read:   if isAuth();
      allow write:  if isHR();
    }

    // ── Leave requests ────────────────────────────────────────────────
    match /leave_requests/{id} {
      allow read:   if isTeamLead() || isAuth();
      allow create: if isAuth();
      allow update: if isHR();
      allow delete: if isHR();
    }

    // ── Advance requests (employee portal) ────────────────────────────
    match /advance_requests/{id} {
      allow read:   if isHR() || isAuth();
      allow create: if isAuth();
      allow update: if isHR();
      allow delete: if isHR();
    }

    // ── Grievances (employee portal) ──────────────────────────────────
    match /grievances/{id} {
      allow read:   if isHR() || isAuth();
      allow create: if isAuth();
      allow update: if isHR();
      allow delete: if isHR();
    }

    // ── Letter requests (employee portal) ─────────────────────────────
    match /letter_requests/{id} {
      allow read:   if isHR() || isAuth();
      allow create: if isAuth();
      allow update: if isHR();
      allow delete: if isHR();
    }

    // ── Overtime requests (employee portal) ───────────────────────────
    match /overtime_requests/{id} {
      allow read:   if isHR() || isAuth();
      allow create: if isAuth();
      allow update: if isHR();
      allow delete: if isHR();
    }

    // ── Employee documents (My Documents portal) ──────────────────────
    match /employee_documents/{id} {
      allow read:   if isHR() || isAuth();
      allow create: if isAuth();
      allow update: if isHR() || isAuth();
      allow delete: if isHR();
    }

    // ── Time entries (punch in/out, My Attendance) ────────────────────
    match /time_entries/{id} {
      allow read:   if isTeamLead() || isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isHR();
    }

    // ── Timesheet approvals ───────────────────────────────────────────
    match /timesheet_approvals/{id} {
      allow read:   if isTeamLead() || isAuth();
      allow create: if isAuth();
      allow update: if isTeamLead();
      allow delete: if isHR();
    }

    // ── Attendance records (HR-marked, My Attendance) ─────────────────
    match /attendance_records/{id} {
      allow read:   if isTeamLead() || isAuth();
      allow write:  if isHR();
    }

    // ── Attendance (legacy HR attendance marking) ─────────────────────
    match /attendance/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }

    // ── Payroll runs + entries sub-collection ─────────────────────────
    match /payroll_runs/{runId} {
      allow read:   if isHR();
      allow write:  if isHR();

      match /entries/{entryId} {
        allow read:   if isHR();
        allow write:  if isHR();
      }
    }

    // ── Advances (HR module) ──────────────────────────────────────────
    match /advances/{id} {
      allow read:   if isHR();
      allow write:  if isHR();
    }

    // ── Loans ─────────────────────────────────────────────────────────
    match /loans/{id} {
      allow read:   if isHR();
      allow write:  if isHR();
    }

    // ── Recruitment / Applicants ──────────────────────────────────────
    match /applicants/{id} {
      allow create: if true;
      allow read:   if isHR();
      allow update: if isHR();
      allow delete: if isHR();
    }

    // ── Timesheets (HR timesheet view) ────────────────────────────────
    match /timesheets/{id} {
      allow read:   if isTeamLead();
      allow write:  if isAuth();
    }

    // ── Performance reviews ───────────────────────────────────────────
    match /performance/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }

    // ── Training ──────────────────────────────────────────────────────
    match /training/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }

    // ── Disciplinary ──────────────────────────────────────────────────
    match /disciplinary/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }

    // ── Staff / misc ──────────────────────────────────────────────────
    match /staff/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }
  }
}
