rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the request from a signed-in user?
    function isAuth() {
      return request.auth != null;
    }

    // Helper: read the caller's user doc to check their role
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin()    { return isAuth() && role() == 'admin'; }
    function isHR()       { return isAuth() && (role() == 'admin' || role() == 'hr'); }
    function isTeamLead() { return isAuth() && (role() == 'admin' || role() == 'hr' || role() == 'team_lead'); }

    // ── Employees ────────────────────────────────────────────────────
    match /employees/{id} {
      allow read:   if isTeamLead();
      allow create: if isHR();
      allow update: if isHR();
      allow delete: if isAdmin();
    }

    // ── Users (portal accounts) ──────────────────────────────────────
    match /users/{id} {
      // Any signed-in user can read their own doc; admin/HR can read all
      allow read:   if isAuth() && (request.auth.uid == id || isHR());
      allow create: if isAdmin();
      allow update: if isAdmin() || request.auth.uid == id;
      allow delete: if isAdmin();
    }

    // ── Attendance ───────────────────────────────────────────────────
    match /attendance/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }

    // ── Leave requests ────────────────────────────────────────────────
    match /leave_requests/{id} {
      allow read:   if isTeamLead();
      allow create: if isHR();
      allow update: if isHR();
      allow delete: if isHR();
    }

    // ── Payroll runs + entries sub-collection ─────────────────────────
    match /payroll_runs/{runId} {
      allow read:   if isHR();
      allow write:  if isHR();

      match /entries/{entryId} {
        allow read:   if isHR();
        allow write:  if isHR();
      }
    }

    // ── Advances ─────────────────────────────────────────────────────
    match /advances/{id} {
      allow read:   if isHR();
      allow write:  if isHR();
    }

    // ── Loans ─────────────────────────────────────────────────────────
    match /loans/{id} {
      allow read:   if isHR();
      allow write:  if isHR();
    }

    // ── Recruitment / Applicants ──────────────────────────────────────
    match /applicants/{id} {
      // Public can create (job applications); HR reads/updates
      allow create: if true;
      allow read:   if isHR();
      allow update: if isHR();
      allow delete: if isHR();
    }

    // ── Timesheets ────────────────────────────────────────────────────
    match /timesheets/{id} {
      allow read:   if isTeamLead();
      allow write:  if isAuth();
    }

    // ── Performance reviews ───────────────────────────────────────────
    match /performance/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }

    // ── Training ──────────────────────────────────────────────────────
    match /training/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }

    // ── Disciplinary ──────────────────────────────────────────────────
    match /disciplinary/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }

    // ── Staff / misc ──────────────────────────────────────────────────
    match /staff/{id} {
      allow read:   if isTeamLead();
      allow write:  if isHR();
    }
  }
}
